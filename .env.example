# --- Required ---
TG_TOKEN=123456:ABC-your-bot-token
TG_CHAT_ID=987654321
DATABASE_URL=file:./radar.db

# --- Freshness / cooldown ---
# Bounties not confirmed by their source within this many days are omitted from feeds.
BOUNTY_MAX_AGE_DAYS=180
# Minimum cooldown between posts of the same bounty (avoids recycling).
BOUNTY_COOLDOWN_DAYS=7

# --- Branding (used in post drafts) ---
X_HANDLE=@unnamedcodes
TG_CHANNEL=https://t.me/your_channel

# --- Schedules (cron, server timezone). Defaults shown. ---
# Source scan: every 6h
SCAN_CRON=0 0 */6 * * *
# Daily drop draft: 09:00 daily
DROP_CRON=0 0 9 * * *
# Closing-soon alerts: every 6h
CLOSING_SOON_CRON=0 0 */6 * * *
# Winner spotlight: Tue & Fri 16:00
SPOTLIGHT_CRON=0 0 16 * * 2,5
# Monthly stats: 1st of month 09:00
STATS_CRON=0 0 9 1 * *

# Hourly feed (rotates Top Pick / Closing Soon / Fresh Find / Active Pick)
HOURLY_FEED_CRON=0 0 * * * *

# Timezone for all schedules (e.g. UTC, America/New_York)
TZ=UTC
